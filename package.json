{
  "name": "rustwebui-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "rsbuild dev --config rsbuild.config.dev.ts",
    "build": "node ../build-frontend.js",
    "build:incremental": "rsbuild build --config rsbuild.config.ts",
    "preview": "rsbuild preview",
    "clean": "rm -rf dist && rm -rf node_modules/.cache",
    "lint": "biome lint src",
    "lint:fix": "biome lint src --write",
    "lint:ci": "biome lint src --reporter=github",
    "format": "biome format src",
    "format:fix": "biome format src --write",
    "format:check": "biome format src --check",
    "check": "biome check src",
    "check:fix": "biome check src --write",
    "check:ci": "biome check src --reporter=github",
    "validate": "biome check src && biome format src --check",
    "validate:fix": "biome check src --write && biome format src --write",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:ci": "bun test --coverage --reporter=junit"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "winbox": "^0.2.82"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@rsbuild/core": "^0.7.0",
    "@rsbuild/plugin-vue": "^0.7.0",
    "@vue/compiler-sfc": "^3.4.0",
    "@types/bun": "^1.0.0",
    "typescript": "^5.0.0"
  }
}